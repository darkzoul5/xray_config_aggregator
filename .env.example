# Configuration Mode
# Set to 'on' to use local file, 'off' to fetch from GitHub
LOCAL_MODE=on

# Local configuration directory (when LOCAL_MODE=on)
# Must contain: config.txt, default-proxy-groups.yaml, default-rules.yaml
CONFIG_DIR=/app/configs

# Remote configuration (when LOCAL_MODE=off)
CONFIG_URL=https://api.github.com/.../file.txt
GITHUB_TOKEN=ghp_dhoauigc7898374yduisdhSDHFHGf7

# Subscription settings
SUB_NAME=Aggregated
SERVER_NAME=domain.or.subdomain
PORT=443
URL=/sub
CLASH_URL=/clash

# Logging
LOG_LEVEL=info

# SSL Certificate paths
CERT_PATH=/etc/letsencrypt/live/domain.or.subdomain
